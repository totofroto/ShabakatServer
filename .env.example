# Shabakat Server — environment variable template
# Copy to .env and fill in secrets (docker-compose picks it up automatically)

# Web UI port
SHABAKAT_PORT=8080

# Seconds between automatic full scans. Set to 0 to disable auto-scan.
SHABAKAT_SCAN_INTERVAL=600

# Persist SQLite database to this path inside the container
SHABAKAT_DATA_DIR=/data

# Log level: error | warn | info | debug | trace
RUST_LOG=info

# Telegram bot alerts — leave blank to disable
SHABAKAT_TELEGRAM_BOT_TOKEN=
SHABAKAT_TELEGRAM_CHAT_ID=

# Admin Authentication (Google OAuth 2.0)
GOOGLE_CLIENT_ID=your_id_here
GOOGLE_CLIENT_SECRET=your_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback
JWT_SECRET=generate-a-secure-random-string-here

